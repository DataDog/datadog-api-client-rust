//! OAuth2 bearer token middleware.
//!
//! This module provides middleware for injecting OAuth2 bearer tokens into HTTP requests.
//! When using [`with_client_and_config`](crate::datadogV2::api_logs::LogsAPI::with_client_and_config)
//! with a custom HTTP client, you can use this middleware to automatically inject bearer tokens
//! obtained from OAuth2 flows.

use async_trait::async_trait;
use reqwest_middleware::{Middleware, Next, Result};
use task_local_extensions::Extensions;

/// Injects `Authorization: Bearer <token>` into every outgoing request.
///
/// This middleware is designed for OAuth2 authentication flows where the bearer token
/// is obtained dynamically (e.g., from an authorization server). It allows using OAuth2
/// tokens with the generated API client without modifying each API call.
///
/// The middleware runs after other request processing, including any API key headers
/// that may be set by individual API methods. The `Authorization` header is distinct
/// from API key headers (`DD-API-KEY`, `DD-APPLICATION-KEY`), so both can coexist
/// on the same request if needed.
///
/// # Example
///
/// ```ignore
/// use datadog::middleware::BearerTokenMiddleware;
/// use reqwest_middleware::ClientBuilder;
///
/// let client = ClientBuilder::new(reqwest::Client::new())
///     .with(BearerTokenMiddleware {
///         token: "your_oauth2_token".to_string(),
///     })
///     .build();
/// ```
pub struct BearerTokenMiddleware {
    /// The OAuth2 bearer token to inject into requests
    pub token: String,
}

#[async_trait]
impl Middleware for BearerTokenMiddleware {
    async fn handle(
        &self,
        mut req: reqwest::Request,
        extensions: &mut Extensions,
        next: Next<'_>,
    ) -> Result<reqwest::Response> {
        req.headers_mut().insert(
            reqwest::header::AUTHORIZATION,
            format!("Bearer {}", self.token)
                .parse()
                .expect("bearer token is valid header value"),
        );
        next.run(req, extensions).await
    }
}
